# Development mode — enables /docs (Swagger), /redoc (ReDoc), /openapi.json.
# Set to "false" in production to disable API documentation.
DEV=true

DATABASE_URL="sqlite:///./sqlite.db"
SECRET_KEY="change-me-to-a-random-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — JSON array of origins allowed for cross-origin requests
BACKEND_CORS_ORIGINS='["http://localhost:3000"]'

# Google OAuth
GOOGLE_CLIENT_ID="your-google-oauth-client-id"

# Razorpay Payment Gateway (replace with your keys)
RAZORPAY_KEY_ID="change-me-to-your-razorpay-key-id"
RAZORPAY_KEY_SECRET="change-me-to-your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="change-me-to-a-random-webhook-secret"

# SMTP (Email Verification — use Gmail App Password for dev)
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-16-char-app-password"
FRONTEND_URL="http://localhost:3000"

# AI Provider (ollama = local Gemma 4 via Ollama, gemini = Google Gemini API)
AI_PROVIDER=ollama
GEMINI_API_KEY="your-gemini-api-key"
AI_MODEL=""

# Typesense Search (optional — SQL ILIKE fallback when disabled)
TYPESENSE_ENABLED=false
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY="your-typesense-api-key"
